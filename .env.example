# 火山引擎方舟平台 (Ark) API 配置
# 注册: https://console.volcengine.com/ark
ARK_API_KEY=your_volcano_engine_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包模型ID (在方舟平台创建推理接入点获取)
ASR_MODEL_ID=your_asr_model_id
LLM_MODEL_ID=your_llm_model_id
TTS_MODEL_ID=your_tts_model_id

# TTS 音色 (可选)
# zh_female_qingxin    清新女声
# zh_female_wanwan     温婉女声
# zh_male_M392_conversation   沉稳男声
TTS_VOICE=zh_female_qingxin

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# 前端配置
FRONTEND_URL=http://localhost:5173
